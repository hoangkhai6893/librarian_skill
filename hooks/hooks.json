{
  "description": "librarian_skill hooks — auto-detect project type and suggest skills on session start",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start\"",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
